# Murshid — environment template. Copy to .env and fill in.
# .env is gitignored; this file ships with empty values.

# ---- LLM provider selection ----
# One of: mock | claude | openai | gemini | falcon-arabic
# Default for Phase 1 / reviewer demo: mock (zero-key path).
LLM_PROVIDER=mock

# ---- Anthropic Claude ----
ANTHROPIC_API_KEY=
# Default model. Alternate (held for judge sanity swap, not bench rotation): claude-opus-4-7
ANTHROPIC_MODEL_ID=claude-sonnet-4-6

# ---- OpenAI ----
OPENAI_API_KEY=
# Default model. Alternate (cost/quality datapoint): gpt-5.4-mini-2026-03-17
OPENAI_MODEL_ID=gpt-5.5-2026-04-23

# ---- Google Gemini ----
# Note: gemini-3-pro-preview was shut down 2026-03-09; use gemini-3.1-pro-preview.
GEMINI_API_KEY=
# Default model. Also serves as the bench judge (out-of-family for Claude/OpenAI).
# Alternate: gemini-3-flash-preview
GEMINI_MODEL_ID=gemini-3.1-pro-preview

# ---- Falcon-Arabic (via Ollama) ----
# Default: Falcon-Arabic 7B. Fallback if hardware is constrained: falcon-h1-arabic:3b
OLLAMA_BASE_URL=http://localhost:11434
FALCON_ARABIC_MODEL=falcon-arabic:7b

# ---- Chunk metadata enrichment (cheap LLM call per chunk during ingest) ----
# Should be the cheapest model available. Defaults to mock for zero-key paths.
# Real options: gpt-5.4-mini-2026-03-17 or claude-haiku-4-5
METADATA_ENRICHMENT_PROVIDER=mock
METADATA_ENRICHMENT_MODEL_ID=

# ---- Normalization knobs ----
# Aggressive normalization (collapses ى → ي, ة → ه, hamza folding). Default false per §0.2.
NORMALIZE_AGGRESSIVE=false

# ---- Bench knobs ----
# Judge model for bench scoring. Out-of-family from Claude/OpenAI by design.
#
# Primary planned judge per kickoff §0.6: `gemini-3.1-pro-preview`.
# Actual Phase 3 default after the first bench run: `gemini-2.5-flash`. Two
# reasons surfaced during the Phase 3 bench:
#   1. Gemini 3.1 Pro Preview emits visible output AFTER an invisible thinking
#      budget that consumes the configured max_tokens before any JSON appears
#      (we saw 29 visible tokens at max_tokens=800; Phase 3 follow-up raised the
#      budget to 4000 in `bench/metrics.py`, but Flash sidesteps the issue).
#   2. Gemini Pro Preview shares a daily 250-request quota even on the paid tier;
#      Flash is in a separate, larger quota bucket.
# Flash is verified stable on Google AI docs; switching to it is documented as a
# measured fallback in ADR 2 (the kickoff still names Pro as the primary plan).
BENCH_JUDGE_MODEL=gemini-2.5-flash

# Sanity-swap judge model (3 cases) to quantify self-preference bias.
# Phase 4 fix: the swap now re-scores the SAME predicted answer across two judges,
# not gold-vs-gold. See `bench/runner.py:run_judge_sanity_swap`.
BENCH_SANITY_SWAP_JUDGE_MODEL=claude-opus-4-7
